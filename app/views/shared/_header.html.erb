<nav class="navbar navbar-expand-lg navbar-light bg-light">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">RUNTEQ 中間試験</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <form class="d-flex" action="<%= posts_path %>" method="get">
        <%= text_field_tag :post, params[:post], placeholder: "投稿", id: "search_field_of_post", class: "form-control me-2" %>
        <%= text_field_tag :comment, params[:comment], placeholder: "コメント", id: "search_field_of_comment", class: "form-control me-2" %>
        <%= text_field_tag :user, params[:user], placeholder: "ユーザー", id: "search_field_of_user", class: "form-control me-2" %>
        <%= submit_tag "Search", class: "btn btn-outline-success" %>
      </form>


      <ul class="navbar-nav mb-2 mb-lg-0 ms-auto">
        <% if current_user.present? %>
          <li class="nav-item">
            <%= link_to '投稿一覧', posts_path, class: 'nav-link' %>
          </li>
          <li class="nav-item">
            <%= link_to '投稿作成', new_post_path, class: 'nav-link' %>
          </li>
          <li class="nav-item">
            <%= button_to "ログアウト", logout_path, method: :delete, class: "btn btn-link nav-link" %>
          </li>
        <% else %>
          <li class="nav-item">
            <%= link_to 'ユーザー登録', sign_up_path, class: 'nav-link' %>
          </li>
          <li class="nav-item">
            <%= link_to 'ログイン', login_path, class: 'nav-link' %>
          </li>
        <% end %>
      </ul>
    </div>
